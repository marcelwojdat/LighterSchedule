DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# Na produkcji: DJANGO_DEBUG=False oraz opcjonalnie:
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000

DB_NAME=lighterschedule_db
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Na produkcji (HTTPS), np.:
# CSRF_TRUSTED_ORIGINS=https://twoja-domena.pl,https://www.twoja-domena.pl

# Rejestracja: False = konta tylko z panelu kierownika (zalecane na produkcji).
# True = otwarta; False + REGISTRATION_INVITE_CODE = tylko z kodem.
ALLOW_PUBLIC_REGISTRATION=False
REGISTRATION_INVITE_CODE=
